# DB
DATABASE_URL="file:./data/app.db"

# LLM（仅 Deepseek 必填，其余按需）
DEEPSEEK_API_KEY=""          # 必填，主用
ANTHROPIC_API_KEY=""         # 扩展位
KIMI_API_KEY=""              # 扩展位
XIAOMI_API_KEY=""            # 扩展位
OPENAI_API_KEY=""            # 扩展位
OLLAMA_BASE_URL="http://localhost:11434/v1"  # 本地 Ollama 地址
OLLAMA_API_KEY=""            # Ollama 通常无需 API Key（可留空）
OLLAMA_DEFAULT_MODEL="qwen2.5:14b"  # 默认模型

# 沙箱
SANDBOX_DOCKER="0"           # 1 = 启用 Docker 沙箱（默认 0 = 子进程）
SANDBOX_TIMEOUT_MS="180000"

# Pi
PI_DEFAULT_PROVIDER="deepseek"
PI_DEFAULT_MODEL="deepseek-chat"
PI_THINKING_LEVEL="medium"

# 其他
NEXT_PUBLIC_APP_URL="http://localhost:3002"  # 服务端 fetch 用
NEXT_PUBLIC_APP_NAME="全栈智码"
NODE_ENV="development"
