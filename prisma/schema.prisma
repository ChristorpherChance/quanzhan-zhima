generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id            String   @id @default(cuid())
  name          String
  oneLiner      String
  ownerId       String   @default("local-user")
  currentStage  String   @default("requirement")
  seedType      String?
  hitlMode      String   @default("manual")
  hitlThreshold Float    @default(0.8)
  confidence    Float?   @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  artifacts     Artifact[]
  conversations Conversation[]
  jobs          Job[]
  gates         Gate[]
  piSessions    PiSession[]

  @@index([currentStage])
  @@index([seedType])
}

model Artifact {
  id          String   @id @default(cuid())
  projectId   String
  type        String
  version     Int      @default(1)
  locked      Boolean  @default(false)
  storagePath String
  meta        String?
  createdAt   DateTime @default(now())
  lockedAt    DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, type])
  @@index([projectId, type, version])
}

model Conversation {
  id           String   @id @default(cuid())
  projectId    String
  agentType    String
  messagesJson String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, agentType])
}

model Job {
  id        String    @id @default(cuid())
  projectId String
  agentType String
  type      String
  status    String    @default("pending")
  logs      String    @default("")
  errorMsg  String?
  meta      String?
  costTokens Int      @default(0)
  startedAt DateTime  @default(now())
  endedAt   DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, agentType])
  @@index([status])
}

model Gate {
  id           String   @id @default(cuid())
  projectId    String
  type         String
  status       String   @default("open")
  mode         String   @default("manual")
  confidence   Float?
  lockedAt     DateTime?
  reopenReason String?
  createdAt    DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, type])
}

model PiSession {
  id         String   @id @default(cuid())
  projectId  String
  agentType  String
  leafId     String?
  modelId    String
  thinking   String   @default("off")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages   Message[]

  @@unique([projectId, agentType])
  @@index([projectId])
}

model Message {
  id        String   @id @default(cuid())
  sessionId String
  role      String
  blocks    String
  ts        DateTime @default(now())
  session   PiSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, ts])
}

// J6: Agent 注册表 — 数据驱动配置
model AgentConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  description String   @default("")
  stage       String
  modelId     String   @default("deepseek-chat")
  provider    String   @default("deepseek")
  temperature Float    @default(0.2)
  maxTokens   Int      @default(4096)
  timeoutMs   Int      @default(600000)
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
  @@index([stage])
}
